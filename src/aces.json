{
	"$schema": "../SDK/plugin-sdk/v1/aces.schema.json",
	"media": {
		"conditions": [
			{
				"id": "on-state-changed",
				"scriptName": "OnStateChanged",
				"isTrigger": true
			},
			{
				"id": "is-playing",
				"scriptName": "IsPlaying"
			},
			{
				"id": "is-paused",
				"scriptName": "IsPaused"
			},
			{
				"id": "is-ended",
				"scriptName": "IsEnded"
			},
			{
				"id": "is-muted",
				"scriptName": "IsMuted"
			},
			{
				"id": "is-loading",
				"scriptName": "IsLoading"
			},
			{
				"id": "is-ready",
				"scriptName": "IsReady"
			}
		],
		"actions": [
			{
				"id": "load",
				"scriptName": "Load",
				"params": [
					{
						"id": "iframeId",
						"type": "string"
					}
				]
			},
			{
				"id": "play",
				"scriptName": "Play"
			},
			{
				"id": "pause",
				"scriptName": "Pause"
			},
			{
				"id": "set-muted",
				"scriptName": "SetMuted",
				"params": [
					{
						"id": "mute",
						"type": "boolean"
					}
				]
			},
			{
				"id": "set-playback-time",
				"scriptName": "SetPlaybackTime",
				"params": [
					{
						"id": "playback-time",
						"type": "number"
					}
				]
			},
			{
				"id": "set-volume",
				"scriptName": "SetVolume",
				"params": [
					{
						"id": "level",
						"type": "number"
					}
				]
			}
		],
		"expressions": [
			{
				"id": "state",
				"expressionName": "State",
				"returnType": "string"
			},
			{
				"id": "get-current-playback-time",
				"expressionName": "GetCurrentPlaybackTime",
				"returnType": "number"
			},
			{
				"id": "get-current-volume",
				"expressionName": "GetCurrentVolume",
				"returnType": "number"
			},
			{
				"id": "get-duration",
				"expressionName": "GetDuration",
				"returnType": "number"
			}
		]
	}
}