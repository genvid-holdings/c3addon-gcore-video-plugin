{
	"$schema": "../SDK/plugin-sdk/v1/aces.schema.json",
	"media": {
		"conditions": [
			{
				"id": "on-state-changed",
				"scriptName": "OnStateChanged",
				"isTrigger": true
			},
			{
				"id": "on-error",
				"scriptName": "OnError",
				"isTrigger": true
			},
			{
				"id": "is-playing",
				"scriptName": "IsPlaying"
			},
			{
				"id": "is-paused",
				"scriptName": "IsPaused"
			},
			{
				"id": "is-ended",
				"scriptName": "IsEnded"
			},
			{
				"id": "is-muted",
				"scriptName": "IsMuted"
			},
			{
				"id": "is-loading",
				"scriptName": "IsLoading"
			},
			{
				"id": "is-ready",
				"scriptName": "IsReady"
			},
			{
				"id": "is-offline",
				"scriptName": "IsOffline"
			}
		],
		"actions": [
			{
				"id": "play",
				"scriptName": "Play"
			},
			{
				"id": "pause",
				"scriptName": "Pause"
			},
			{
				"id": "set-muted",
				"scriptName": "SetMuted",
				"params": [
					{
						"id": "mute",
						"type": "boolean"
					}
				]
			},
			{
				"id": "set-playback-time",
				"scriptName": "SetPlaybackTime",
				"params": [
					{
						"id": "playback-time",
						"type": "number"
					}
				]
			},
			{
				"id": "set-volume",
				"scriptName": "SetVolume",
				"params": [
					{
						"id": "level",
						"type": "number"
					}
				]
			},
			{
				"id": "set-url",
				"scriptName": "SetURL",
				"params": [
					{
						"id": "url",
						"type": "string"
					},
					{
						"id": "subtitles",
						"type": "string"
					},
					{
						"id": "no-low-latency",
						"type": "boolean"
					}
				]
			},
			{
				"id": "set-subtitles",
				"scriptName": "SetSubtitles",
				"params": [
					{
						"id": "language",
						"type": "string"
					}
				]
			},
			{
				"id": "set-no-low-latency",
				"scriptName": "SetNoLowLatency",
				"params": [
					{
						"id": "noLowLatency",
						"type": "boolean"
					}
				]
			},
			{
				"id": "set-quality",
				"scriptName": "SetQuality",
				"params": [
					{
						"id": "level",
						"type": "number"
					}
				]
			},
			{
				"id": "set-enable-chrome",
				"scriptName": "SetEnableChrome",
				"params": [
					{
						"id": "enable",
						"type": "boolean"
					}
				]
			},
			{
				"id": "set-fallback-urls",
				"scriptName": "SetFallbackURLs",
				"params": [
					{
						"id": "urls",
						"type": "string"
					}
				]
			},
			{
				"id": "add-subtitle-source",
				"scriptName": "AddSubtitleSource",
				"params": [
					{
						"id": "url",
						"type": "string"
					},
					{
						"id": "language",
						"type": "string"
					},
					{
						"id": "label",
						"type": "string"
					}
				]
			},
			{
				"id": "resize",
				"scriptName": "Resize"
			}
		],
		"expressions": [
			{
				"id": "state",
				"expressionName": "State",
				"returnType": "string"
			},
			{
				"id": "get-last-error-message",
				"expressionName": "GetLastErrorMessage",
				"returnType": "string"
			},
			{
				"id": "get-last-error-category",
				"expressionName": "GetLastErrorCategory",
				"returnType": "string"
			},
			{
				"id": "get-current-playback-time",
				"expressionName": "GetCurrentPlaybackTime",
				"returnType": "number"
			},
			{
				"id": "get-current-volume",
				"expressionName": "GetCurrentVolume",
				"returnType": "number"
			},
			{
				"id": "get-duration",
				"expressionName": "GetDuration",
				"returnType": "number"
			},
			{
				"id": "url",
				"expressionName": "URL",
				"returnType": "string"
			},
			{
				"id": "subtitles",
				"expressionName": "Subtitles",
				"returnType": "string"
			},
			{
				"id": "no-low-latency",
				"expressionName": "NoLowLatency",
				"returnType": "number"
			},
			{
				"id": "get-enable-chrome",
				"expressionName": "GetEnableChrome",
				"returnType": "number"
			},
			{
				"id": "get-current-quality",
				"expressionName": "GetCurrentQuality",
				"returnType": "number"
			},
			{
				"id": "get-quality-count",
				"expressionName": "GetQualityCount",
				"returnType": "number"
			}
		]
	}
}