{
  "project": {
    "name": "c3addon-gcore-video-player",
    "description": "Construct3 GCore Video Player add-on by Genvid",
    "languages": ["typescript", "javascript"]
  },
  "commands": {
    "test": "",
    "lint": "npm run lint",
    "build": "npm run build",
    "validate": "npm run lint && npm run build"
  },
  "repo": {
    "host": "github",
    "default_branch": "main"
  },
  "features": {},
  "paths": {
    "c3project": "sample/project.c3proj"
  },
  "bugTracker": {
    "kind": "github",
    "actionQuery": "gh issue list --state open -L 200 --json number,title,labels,body,assignees",
    "comparisonQuery": "gh issue list --state all -L 500 --json number,title,labels,state",
    "readOne": "gh issue view {id} --json number,title,body,labels,comments",
    "triagedLabel": "triaged",
    "needsInfoLabel": "needs-info"
  }
}
